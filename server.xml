<server description="Insurance SOAP Liberty Server">

  <featureManager>
    <feature>webProfile-8.0</feature>
    <feature>jaxws-2.2</feature>
    <feature>localConnector-1.0</feature>
  </featureManager>

  <httpEndpoint id="defaultHttpEndpoint"
    host="*"
    httpPort="9080"
    httpsPort="9443" />

  <!-- H2 in-memory database driver library -->
  <library id="H2Lib">
    <file name="/opt/ibm/wlp/usr/shared/resources/h2.jar"/>
  </library>

  <!--
    jndiName MUST be jdbc/InsuranceDB (no java:app/ prefix) for a server-level
    dataSource. java:app/ is only valid inside an application deployment descriptor.
  -->
  <dataSource id="InsuranceDB" jndiName="jdbc/InsuranceDB">
    <jdbcDriver libraryRef="H2Lib"/>
    <properties.h2.embedded url="jdbc:h2:mem:insurance;DB_CLOSE_DELAY=-1" user="sa" password=""/>
  </dataSource>

  <!-- The WAR is deployed via the server dropins directory in the Docker image. -->

</server>