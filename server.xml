<server description="Insurance SOAP Liberty Server">
<featureManager>
<feature>servlet-4.0</feature>
<feature>jsp-2.3</feature>
<feature>jaxws-2.2</feature>
	<!-- Enable JPA and JDBC support for the application's persistence and @DataSourceDefinition -->
	<feature>jpa-2.2</feature>
	<feature>jpaContainer-2.2</feature>
	<feature>jdbc-4.2</feature>
<feature>ejbLite-3.2</feature>
<feature>cdi-2.0</feature>
<feature>localConnector-1.0</feature>
</featureManager>
<httpEndpoint id="defaultHttpEndpoint"
host="*"
httpPort="9080"
httpsPort="9443" />
<!-- Server-side H2 library for the demo persistence unit.
	 This provides the H2 driver classes for @DataSourceDefinition. -->
<library id="H2Lib">
    <file name="/opt/ibm/wlp/usr/shared/resources/h2.jar"/>
</library>
<!-- Make the H2 shared library available to all applications for @DataSourceDefinition -->
<classloader commonLibraryRef="H2Lib"/>
<!-- The WAR is deployed via the server dropins directory in the Docker image. -->
</server>