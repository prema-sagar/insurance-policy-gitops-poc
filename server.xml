<server description="Insurance SOAP Liberty Server">
<featureManager>
<feature>servlet-5.0</feature>
<feature>jsp-3.1</feature>
<feature>jaxws-3.0</feature>
  <!-- Enable JPA and JDBC support for the application's persistence and @DataSourceDefinition -->
  <feature>jpa-3.0</feature>
  <feature>jdbc-4.3</feature>
<feature>ejbLite-4.0</feature>
<feature>cdi-3.0</feature>
<feature>localConnector-2.0</feature>
</featureManager>
<httpEndpoint id="defaultHttpEndpoint"
host="*"
httpPort="9080"
httpsPort="9443" />
<!-- Server-side H2 library and datasource for the demo persistence unit.
	 This makes the DataSource available as java:app/jdbc/InsuranceDB so the
	 application does not need an @DataSourceDefinition annotation. -->
<library id="H2Lib">
    <file name="/opt/ol/wlp/usr/shared/resources/h2.jar"/>
	<properties url="jdbc:h2:mem:insurance;DB_CLOSE_DELAY=-1" user="sa" password=""/>
</dataSource>
<!-- The WAR is deployed via the server dropins directory in the Docker image.
	Do not declare a duplicate <webApplication> entry here (that would try to
	deploy the same application twice and cause the "two applications called" error). -->
</server>