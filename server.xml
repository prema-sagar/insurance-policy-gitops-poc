<server description="Insurance SOAP Liberty Server">

  <featureManager>
    <feature>webProfile-8.0</feature>
    <feature>jaxws-2.2</feature>
    <feature>localConnector-1.0</feature>
  </featureManager>

  <httpEndpoint id="defaultHttpEndpoint"
    host="*"
    httpPort="9080"
    httpsPort="9443" />

  <!--
    H2 driver jar - copied into the image by the Dockerfile.
    Must live at server level so the container-managed DataSource can load it.
  -->
  <library id="H2Lib">
    <file name="/opt/ibm/wlp/usr/shared/resources/h2.jar"/>
  </library>

  <!--
    jndiName must be  jdbc/InsuranceDB  (no java:app/ prefix).
    java:app/ is an application-scoped namespace; server.xml datasources
    live in the global jdbc/ namespace and are looked up as jdbc/InsuranceDB.

    Use plain <properties> (not <properties.h2.embedded>).
    The .h2.embedded variant tells Liberty to omit the URL and use its own
    embedded engine path, which breaks H2's mem: URL entirely.
  -->
  <dataSource id="InsuranceDB" jndiName="jdbc/InsuranceDB">
    <jdbcDriver libraryRef="H2Lib"/>
    <properties
      url="jdbc:h2:mem:insurance;DB_CLOSE_DELAY=-1"
      user="sa"
      password=""/>
  </dataSource>

</server>