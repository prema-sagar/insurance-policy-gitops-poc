<server description="Insurance SOAP Liberty Server">

  <featureManager>
    <feature>webProfile-8.0</feature>
    <feature>jaxws-2.2</feature>
    <feature>localConnector-1.0</feature>
  </featureManager>

  <httpEndpoint id="defaultHttpEndpoint"
    host="*"
    httpPort="9080"
    httpsPort="9443"/>

  <!-- ✅ ADD THIS -->
  <application location="InsuranceApp.war" contextRoot="/InsuranceApp"/>

  <library id="DerbyLib">
    <fileset dir="${shared.resource.dir}/derby" includes="*.jar"/>
  </library>

  <dataSource id="InsuranceDB" jndiName="jdbc/InsuranceDB">
    <jdbcDriver libraryRef="DerbyLib"/>
    <properties.derby.embedded
      databaseName="memory:insuranceDB"
      createDatabase="create"/>
  </dataSource>

</server>